{
  "name": "ui-ecosystem",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint && pnpm lint:oxc",
    "lint:oxc": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
